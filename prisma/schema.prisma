// Prisma Schema - Clínica Bello Horizonte

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  USER
  DOCTOR
  ADMIN
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  RESCHEDULED
  POSTPONED
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  dni          String   @unique
  email        String   @unique
  phone        String
  firstName    String   @map("first_name")
  lastName     String   @map("last_name")
  birthDate    String?  @map("birth_date")
  passwordHash String   @map("password_hash")
  role         Role     @default(USER)
  fcmToken     String?  @map("fcm_token")
  photoUrl     String?  @map("photo_url")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  refreshTokens   RefreshToken[]
  appointments    Appointment[]
  patientRecords  PatientRecord[]
  doctor          Doctor?
  waitlistEntries WaitlistEntry[]
  passwordResets  PasswordReset[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  tokenHash String   @map("token_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Specialty {
  id          String  @id @default(uuid())
  name        String  @unique
  description String?
  icon        String?
  color       String?

  doctors      Doctor[]
  appointments Appointment[]

  @@map("specialties")
}

model Doctor {
  id              String   @id @default(uuid())
  userId          String?  @unique @map("user_id")
  firstName       String   @map("first_name")
  lastName        String   @map("last_name")
  specialtyId     String   @map("specialty_id")
  description     String?
  photoUrl        String?  @map("photo_url")
  rating          Float    @default(0)
  ratingCount     Int      @default(0) @map("rating_count")
  yearsExperience Int      @default(0) @map("years_experience")
  consultationFee Float    @default(0) @map("consultation_fee")
  availableDays   Int[]    @map("available_days")
  createdAt       DateTime @default(now()) @map("created_at")

  user          User?          @relation(fields: [userId], references: [id])
  specialty     Specialty      @relation(fields: [specialtyId], references: [id])
  appointments  Appointment[]
  ratings       DoctorRating[]
  waitlistEntries WaitlistEntry[]

  @@map("doctors")
}

model Appointment {
  id              String            @id @default(uuid())
  userId          String            @map("user_id")
  doctorId        String            @map("doctor_id")
  specialtyId     String            @map("specialty_id")
  appointmentDate String            @map("appointment_date")
  appointmentTime String            @map("appointment_time")
  status          AppointmentStatus @default(PENDING)
  reason          String?
  notes           String?
  cancelReason    String?           @map("cancel_reason")
  postponeReason  String?           @map("postpone_reason")
  newDate         String?           @map("new_date")
  newTime         String?           @map("new_time")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  user          User           @relation(fields: [userId], references: [id])
  doctor        Doctor         @relation(fields: [doctorId], references: [id])
  specialty     Specialty      @relation(fields: [specialtyId], references: [id])
  patientRecord PatientRecord?
  rating        DoctorRating?

  @@unique([doctorId, appointmentDate, appointmentTime])
  @@map("appointments")
}

model DoctorRating {
  id            String   @id @default(uuid())
  appointmentId String   @unique @map("appointment_id")
  doctorId      String   @map("doctor_id")
  userId        String   @map("user_id")
  stars         Int
  comment       String?
  createdAt     DateTime @default(now()) @map("created_at")

  appointment Appointment @relation(fields: [appointmentId], references: [id])
  doctor      Doctor      @relation(fields: [doctorId], references: [id])

  @@map("doctor_ratings")
}

model WaitlistEntry {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  doctorId  String   @map("doctor_id")
  date      String
  time      String
  createdAt DateTime @default(now()) @map("created_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@unique([userId, doctorId, date, time])
  @@map("waitlist_entries")
}

model PatientRecord {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  appointmentId String?  @unique @map("appointment_id")
  diagnosis     String?
  treatment     String?
  notes         String?
  recordDate    String   @map("record_date")
  doctorName    String?  @map("doctor_name")
  specialtyName String?  @map("specialty_name")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user        User         @relation(fields: [userId], references: [id])
  appointment Appointment? @relation(fields: [appointmentId], references: [id])

  @@map("patient_records")
}

model PasswordReset {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  code      String
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_resets")
}
